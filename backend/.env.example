# App Service running locally against the canonical Docker stack
DB_HOST=localhost
DB_PORT=15432
DB_NAME=quranapp_app_clean
DB_USER=app_admin
DB_PASSWORD=change-me-app-db

# AI Services
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
LLM_MODEL=gemini-2.0-flash

# Security
SECRET_KEY=change-me-app-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Resource service integration
RESOURCE_SERVICE_ENABLED=true
RESOURCE_SERVICE_BASE_URL=http://localhost:18100/api/v1
RESOURCE_SERVICE_TOKEN=change-me-internal-token
RESOURCE_SERVICE_TIMEOUT_SECONDS=15

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:19006
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+)(:\d+)?$
