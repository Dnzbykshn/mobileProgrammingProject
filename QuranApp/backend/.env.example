# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=islamic_knowledge_source
DB_USER=admin
DB_PASSWORD=your-db-password

# === Redis ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_CACHE_TTL=86400

# === AI Services ===
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
LLM_MODEL=gemini-2.0-flash

# === Security ===
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# === CORS ===
# Comma-separated explicit origins
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:19006
# Regex fallback for local development hosts
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|10\\.0\\.2\\.2|192\\.168\\.\\d+\\.\\d+)(:\\d+)?$
