# Resource Service running locally against the canonical Docker stack
DB_HOST=localhost
DB_PORT=15433
DB_NAME=quranapp_resources_clean
DB_USER=resource_admin
DB_PASSWORD=change-me-resource-db

# AI / Embedding
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=models/gemini-embedding-001
