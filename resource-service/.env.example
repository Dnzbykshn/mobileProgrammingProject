# Graph
NEO4J_URI=bolt://localhost:17688
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-resource-neo4j
GRAPH_CONTEXT_ENABLED=true

# Internal service auth
SERVICE_AUTH_TOKEN=change-me-internal-token
